#include<stdio.h>
#include<stdlib.h>
int main()
{
    int ch;
    while(1)
    {
    printf("Enter Construction Type\n 1.Residential Building\n 2.Commercial Building\n 3.Bridge Construction\n 4.Road Construction\n 5.Exit\n");
    scanf("%d",&ch);
    switch(ch)
    {
        case 1:
        printf("Materials Required : Brick & RCC\n");
        break;
        case 2:
        printf("Materials Required : RCC & Steel\n");
        break;
        case 3:
        printf("Materials Required : Prestressed Concrete & Steel\n");
        break;
        case 4:
        printf("Materials Required : Concrete & Bitumen \n");
        break;
        case 5:
        exit(0);
        default:
        printf("Enter The Valid Option\n");
    }
    }
    return 0;
}
