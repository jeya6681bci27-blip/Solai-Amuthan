1) #include <stdio.h>
int main() {
    int rows,columns,i,j;
    printf("Enter the no.of Rows:");
    scanf("%d",&rows);
    printf("Enter the no.of Columns:");
    scanf("%d",&columns);
    printf("\n");
    for(i=1;i<=rows;i++)
    {
        for(j=1;j<=columns;j++)
        {
            printf("*");
        }
        printf("\n");
    }
    return 0;
}
